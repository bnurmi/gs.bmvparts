	<!--Typedefinitionen der Responses-->
	<xs:complexType name="typeDmsResponse">
		<xs:annotation>
			<xs:documentation>Generic response element containing required overhead</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element ref="ergebnisCode"/>
			<xs:element name="messageText" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Messagetext from the DMS. This text is displayed unchanged without further comment by the ETK. The message is displayed independently from the value of ergebnisCode.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:minLength value="0"/>
						<xs:maxLength value="128"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="typeInitResponse">
		<xs:annotation>
			<xs:documentation>Response of initialisation containing information about the DMS</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="firma" type="typeString256">
						<xs:annotation>
							<xs:documentation>The firm of the user. This is Name of the firm.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="PLZ">
						<xs:annotation>
							<xs:documentation>The ZIP code</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:maxLength value="10"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="ort" type="typeString256">
						<xs:annotation>
							<xs:documentation>The city</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="strasse" type="typeString256">
						<xs:annotation>
							<xs:documentation>The address</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="telefon" type="typeString30">
						<xs:annotation>
							<xs:documentation>The telephone</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="haendlernummerPkw" type="typeHaendlernummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The dealer number for car selling dealers</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="haendlernummerKrad" type="typeHaendlernummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The dealer number for motor cycle selling dealers</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummerBarverkauf" type="typeKundennummer">
						<xs:annotation>
							<xs:documentation>The customer number that is to be used for cash sales</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="mehrwertsteuer" type="typeMehrwertsteuerSatz" minOccurs="0" maxOccurs="5">
						<xs:annotation>
							<xs:documentation>Different VAT's. The VAT is differenciated by a type attribute</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="ATSteuer" type="typeDecimal3.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Additional taxes</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="nachkommastellen" default="2">
						<xs:annotation>
							<xs:documentation>The number of positions after decimal point. This number can have a maximum of 2 digits.</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:integer">
								<xs:totalDigits value="2"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="ausfuehrungsart" type="typeDmsAusfuehrungsart">
						<xs:annotation>
							<xs:documentation>Indicator, if the DMS works set or order oriented</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="marke" type="typeMarke">
						<xs:annotation>
							<xs:documentation>The default marque (BMW, MINI, Rolls-Royce)</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeStammsatzanlageResponse">
		<xs:annotation>
			<xs:documentation>Success information on the request to create a master record</xs:documentation>
