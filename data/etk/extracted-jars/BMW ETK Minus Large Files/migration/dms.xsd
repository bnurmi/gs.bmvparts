	<xs:complexType name="typeKostenvoranschlagRequest">
		<xs:annotation>
			<xs:documentation>Request for a proposal for the given parts in the list</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsRequest">
				<xs:sequence>
					<xs:annotation>
						<xs:documentation>Information about the parts, user and order</xs:documentation>
					</xs:annotation>
					<xs:element name="position" type="kompletteBestelllistenPosition" maxOccurs="unbounded">
						<xs:annotation>
							<xs:documentation>For each part exists one entry containing the information about the part and order</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="mitarbeiterNr">
						<xs:annotation>
							<xs:documentation>The identification number of the user to be stored in the DMS. Maximum number of digits is 3.</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:positiveInteger">
								<xs:totalDigits value="3"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="kommentar" type="typeString512" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Space for commenty</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The order number, if one exists</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummer" type="typeKundennummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The customer number of the customer who is buying the parts.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<!--ENTFALLEN:Rover-Teilenummer-->
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeWerkstattauftragRequest">
		<xs:annotation>
			<xs:documentation>Request for an order for the given parts in the list</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeKostenvoranschlagRequest">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer">
