<?xml version="1.0" encoding="UTF-8"?>
<!-- edited with XMLSPY v5 rel. 4 U (http://www.xmlspy.com) by Walter L. Goebel (ESG Elektroniksystem und Logitstik) -->
<xs:schema targetNamespace="http://bmw.de/dms" xmlns="http://bmw.de/dms" xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<!--Allgemeine Typedefinitionen (Generell typedefinitions)-->
	<xs:simpleType name="typeString30">
		<xs:annotation>
			<xs:documentation>A string containing 30 characters at max</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:normalizedString">
			<xs:maxLength value="30"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeString256">
		<xs:annotation>
			<xs:documentation>A string containing 256 characters at max</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="256"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeString512">
		<xs:annotation>
			<xs:documentation>A string containing 512 characters at max</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="512"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeDecimal3.2">
		<xs:annotation>
			<xs:documentation>Decimal values in the format 3.2</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:decimal">
			<xs:totalDigits value="5"/>
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeDecimal6.2">
		<xs:annotation>
			<xs:documentation>Decimal values in the format 6.2</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:decimal">
			<xs:totalDigits value="8"/>
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeDecimal8.2">
		<xs:annotation>
			<xs:documentation>Decimal values in the format 8.2</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:decimal">
			<xs:totalDigits value="10"/>
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeDecimal9.2">
		<xs:annotation>
			<xs:documentation>Decimal vallues in the format 9.2</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:decimal">
			<xs:totalDigits value="11"/>
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DMS Basisdatentypen (DMS basic types)-->
	<!--Typen für Identifikation (Type for identification purpose)-->
	<xs:simpleType name="typeUsername">
		<xs:annotation>
			<xs:documentation>Name of the user. This is only unique with a given firm parameter</xs:documentation>
		</xs:annotation>
		<xs:restriction base="typeString30"/>
	</xs:simpleType>
	<xs:simpleType name="typeFirma">
		<xs:annotation>
			<xs:documentation>Name of the firm of the user</xs:documentation>
		</xs:annotation>
		<xs:restriction base="typeString30">
			<xs:whiteSpace value="collapse"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeFiliale">
		<xs:annotation>
			<xs:documentation>Name of the branch the user is currently working in</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:NMTOKEN">
			<xs:minLength value="1"/>
			<xs:maxLength value="4"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeHaendlernummer">
		<xs:annotation>
			<xs:documentation>A datatype for dealer numbers</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:NMTOKEN">
			<xs:pattern value="[0-9]{5}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeAuftragsnummer">
		<xs:annotation>
			<xs:documentation>An order number from the DMS</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:NMTOKEN">
			<xs:maxLength value="10"/>
			<xs:minLength value="1"/>
			<xs:whiteSpace value="collapse"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeKundennummer">
		<xs:annotation>
			<xs:documentation>A customer number. The maximum number of digits is 7.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger">
			<xs:totalDigits value="7"/>
			<xs:fractionDigits value="0"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeFahrgestellnummer">
		<xs:annotation>
			<xs:documentation>A vehicle identification number</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="20"/>
			<xs:minLength value="7"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeProduktklasse">
		<xs:annotation>
			<xs:documentation>A datatype for product classes</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeTeileart">
		<xs:annotation>
			<xs:documentation>Indentifier for part types</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="1"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeTeilenummer">
		<xs:annotation>
			<xs:documentation>Part number, it can have any format, though in BMW it has either 7 or 11-digits</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="11"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeNummernArt">
		<xs:annotation>
			<xs:documentation>Kind of the number(TEILENUMMER = part number or ARBEITSWERTNUMMER = flat rate number)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="20"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typePaketnummer">
		<xs:annotation>
			<xs:documentation>Package number</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="13"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Typen für Wertemengen (Datatypes for value sets)-->
	<xs:simpleType name="typeMarke">
		<xs:annotation>
			<xs:documentation>All possible marques</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:NMTOKEN">
			<xs:enumeration value="BMW"/>
			<xs:enumeration value="MINI"/>
			<xs:enumeration value="Rolls-Royce"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeMwstArten">
		<xs:annotation>
			<xs:documentation>Different types of VAT. The valid values are numbers from 1-5 where each number my appear only once</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:integer">
			<xs:minInclusive value="1"/>
			<xs:maxInclusive value="5"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeKodierungsstufe">
		<xs:annotation>
			<xs:documentation>Identifier for discount types</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeBedarfshinweisCode">
		<xs:annotation>
			<xs:documentation>Valid codes for remarks on requirements. The codes can have up to 2 digits.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger">
			<xs:totalDigits value="2"/>
			<xs:fractionDigits value="0"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeDmsAusfuehrungsart">
		<xs:annotation>
			<xs:documentation>The type of execution the DMS supports (order oriented or set oriented)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:NMTOKEN">
			<xs:enumeration value="satz"/>
			<xs:enumeration value="auftrag"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeDMSErgebnisCodes">
		<xs:annotation>
			<xs:documentation>All valid resullt codes of the DMS. The code can have up to 4 digits. The valid codes are: 0, 1701, 1702, 1705, 1706, 1707, 1708, 1709, 1710, 1741, 1742, 1743, 1744, 1746, 1748, 1749, 1750, 1751, 1752, 1754, 1756, 1757, 1758, 1760, 1762, 1763, 1765, 1800, 1801, 1802, 1810, 1820, 1825, 1900, 1902, 1904, 1906, 1907, 1908, 1930, 1935
			</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger">
			<xs:totalDigits value="4"/>
			<xs:fractionDigits value="0"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Typen für String-Datenformate (Types for strings)-->
	<xs:simpleType name="typeDMSTeilebezeichnung">
		<xs:annotation>
			<xs:documentation>Description of a part limited to 40 characters as defined in the DMS</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="40"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeLagerort">
		<xs:annotation>
			<xs:documentation>Storage location of parts</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="8"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="typeWaehrung">
		<xs:annotation>
			<xs:documentation>Valid currencies (this type is obsolete because currencies are not supported by the interface)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:NMTOKEN">
			<xs:minLength value="2"/>
			<xs:maxLength value="4"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Typen für Zahlenformate (Types for digital values)-->
	<xs:simpleType name="typeOneDigitCode">
		<xs:annotation>
			<xs:documentation>A one-digit code</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger">
			<xs:totalDigits value="1"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Komplexe Datentypen-->
	<xs:complexType name="typeMehrwertsteuerSatz">
		<xs:annotation>
			<xs:documentation>A VAT consisting of the type and the percentage of the VAT</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="mwstId" type="typeMwstArten">
				<xs:annotation>
					<xs:documentation>The ID of the VAT. Valid values are 1-5, where 1 indicates the high and 2 the low VAT. The other numbers are for free use.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="steuersatz" type="typeDecimal3.2">
				<xs:annotation>
					<xs:documentation>The percentage of the VAT</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="teilelistenPosition">
		<xs:annotation>
			<xs:documentation>An entry in a partlist containing information about parts</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="teilenummer" type="typeTeilenummer">
				<xs:annotation>
					<xs:documentation>Part number according to the 11-digit format</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="marke" type="typeMarke">
				<xs:annotation>
					<xs:documentation>The marque of the part</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="bestelllistenPosition">
		<xs:annotation>
			<xs:documentation>An entry in a partlist for ordering parts (inlcudes quantity)</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="teilelistenPosition">
				<xs:sequence>
					<xs:element name="bezeichnung" type="typeDMSTeilebezeichnung">
						<xs:annotation>
							<xs:documentation>Description of the part limited to 40 characters according to DMS format</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="menge" type="typeDecimal8.2">
						<xs:annotation>
							<xs:documentation>The quantity of the part</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="erweiterteBestellistenPosition">
		<xs:annotation>
			<xs:documentation>An entry in an enhanced partlist for ordering parts (inlcudes quantity, comments, order numbers etc.)</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="bestelllistenPosition">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The order number if available</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummer" type="typeKundennummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The customer number if available</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kommentar" type="typeString30" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Space for comments and other information. This field can contain the name of the customer in order to allow mapping of the ordered parts to customers. This mapping is also possible via customer number</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="kompletteBestelllistenPosition">
		<xs:annotation>
			<xs:documentation>An entry in a complete partlist for ordering parts (inlcudes additionally prices discounts, etc.)</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="bestelllistenPosition">
				<xs:sequence>
					<xs:element name="nettopreis" type="typeDecimal9.2">
						<xs:annotation>
							<xs:documentation>price (UPE)</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="preisPreisdatei" type="typeDecimal9.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The price from the price module</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="rabatt">
						<xs:annotation>
							<xs:documentation>Percentage of the discount. This is a String, so +X meaning an addition instead of a reduction (X or -X) can be expressed.</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:minLength value="0"/>
								<xs:maxLength value="7"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="kodierungsstufe" type="typeKodierungsstufe" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Code of the discount</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="suffix" type="typeOneDigitCode" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Suffix</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="splitKennzeichen" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Split code, used for splitting the costs (customer, subsidiary, warranty , etc.). This code can have up to 2 digits.</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:positiveInteger">
								<xs:totalDigits value="2"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="produktklasse" type="typeProduktklasse" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Porduct class of the part</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="teileart" type="typeTeileart" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Type of the part</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="RT" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Job number and sub-job-number (Rechnungstransparenz)</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:maxLength value="4"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="SNP" type="typeDecimal9.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Special price</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kommentar" type="typeString30" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Space for comments and other information. This field can contain the name of the customer in order to allow mapping of the ordered parts to customers. This mapping is also possible via customer number</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<!--Typdefinitionen der Requests (Request types)-->
	<xs:complexType name="typeDmsRequest">
		<xs:annotation>
			<xs:documentation>Generic request element containing required overhead</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:annotation>
				<xs:documentation>This information is required for the identification of the user and the branch he is working from.</xs:documentation>
			</xs:annotation>
			<xs:element name="username" type="typeUsername">
				<xs:annotation>
					<xs:documentation>The login of the user who uses the system</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="firma" type="typeFirma">
				<xs:annotation>
					<xs:documentation>The firm of the user, because the login is only unqiue under a given firm. This is the ID of the firm.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="filiale">
				<xs:annotation>
					<xs:documentation>The branch the user is working from</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="typeFiliale">
						<xs:whiteSpace value="collapse"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="typeInitRequest">
		<xs:annotation>
			<xs:documentation>Request for initialisation and querying the DMS data</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsRequest">
				<xs:sequence>
					<xs:element name="password" type="typeString30">
						<xs:annotation>
							<xs:documentation>The passwort of the user</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeStammsatzanlageRequest">
		<xs:annotation>
			<xs:documentation>Request for creating a master record for a part</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsRequest">
				<xs:sequence>
					<xs:element name="teilenummer" type="typeTeilenummer">
						<xs:annotation>
							<xs:documentation>The part number of the part for that the master record is to be created</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="marke" type="typeMarke">
						<xs:annotation>
							<xs:documentation>The marqueof the part for that the master record is to be created</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="bezeichnung" type="typeDMSTeilebezeichnung">
						<xs:annotation>
							<xs:documentation>The description of the part for that the master record is to be created reduced to 40 characters in order to be handleable by the DMS</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="UPE" type="typeDecimal9.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The net price</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="SNP" type="typeDecimal9.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Special price</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kodierungsstufe" type="typeKodierungsstufe" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Discount key</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="produktklasse" type="typeProduktklasse">
						<xs:annotation>
							<xs:documentation>The product class of the part</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="teileart" type="typeTeileart">
						<xs:annotation>
							<xs:documentation>The type of the part (lacquer, lubricant, etc.)</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="VVM" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Quantity which is contained in the smallest package unit. The number of digits is restricted to 3</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:nonNegativeInteger">
								<xs:totalDigits value="3"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="LVM" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Quantity for packaging for storage. Maximum number of digits is 5.</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:nonNegativeInteger">
								<xs:totalDigits value="5"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="BVM" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Quantity for packaging in containers.Maximum number of digits is 7.</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:nonNegativeInteger">
								<xs:totalDigits value="7"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="hoherMWST" type="xs:boolean" minOccurs="0">
						<xs:annotation>
							<xs:documentation>This indicator defines what VAT should be used, the high or the low. If this value is true the high VAT is used.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<!--Was sollen die Felder für MWST bewirken?-->
					<!--ENTFALLEN: Rover Teilenummer-->
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeTeilelisteInfoRequest">
		<xs:annotation>
			<xs:documentation>Request for information about the parts given in the partlist</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsRequest">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The order number for the given list of parts</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummer" type="typeKundennummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The customer number of the customer that is related to the order of this list</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="vin" type="typeFahrgestellnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The vehicle identification number, if the parts  in the list are part of a package and flat rates should be returned</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="paketnummer" type="typePaketnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Package number, if the parts in the list are part of a package and flat rates should be returned</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="marke" type="typeMarke">
						<xs:annotation>
							<xs:documentation>The marque of the parts in the list. All parts in the list must have the same marque</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:sequence maxOccurs="unbounded">
						<xs:element name="teilenummer" type="typeTeilenummer">
							<xs:annotation>
								<xs:documentation>The part numbers of the parts for which the information is requested. Can be a flat rate number instead, see field art. </xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="art" type="typeNummernArt" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Kind of the number in field teilenummer. If not set the number is a part number. If the field is set to ARBEITSWERTNUMMER the number is a flat rate number.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
					<!--ENTFALLEN:Rover-Teilenummer-->
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
