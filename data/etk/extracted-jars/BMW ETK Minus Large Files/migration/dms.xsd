					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeBarverkaufRequest">
		<xs:annotation>
			<xs:documentation>Request for cash sale for the given parts in the list</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeKostenvoranschlagRequest">
				<xs:sequence>
					<xs:annotation>
						<xs:documentation>Additional information to control required printouts and special cash sale fields</xs:documentation>
					</xs:annotation>
					<xs:element name="kundennummer" type="typeKundennummer">
						<xs:annotation>
							<xs:documentation>The customer number of the customer who is buying the parts. This can the default number as provided by the DMS during initialization</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="passwort">
						<xs:annotation>
							<xs:documentation>The passwort of the user</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:maxLength value="10"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="rechnung" type="xs:boolean">
						<xs:annotation>
							<xs:documentation>Indicates whether an invoice is to be printed. 0 = no invoice / 1 = invoice required</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="greiferschein" type="xs:boolean">
						<xs:annotation>
							<xs:documentation>Indicates whether a printout containing information about the part and its storage is required</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="lieferschein" type="xs:boolean">
						<xs:annotation>
							<xs:documentation>Indicates whether a delivery note is to be printed. 0 = no delivery note / 1 = delivery note required</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kredit" type="typeOneDigitCode" default="0" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Special control value with valid values 0-9, Default = 0; also called "Sondersteuerung"</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="bar" type="typeDecimal9.2">
						<xs:annotation>
							<xs:documentation>The amount the customer paid cash</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="unbar" type="typeDecimal9.2">
						<xs:annotation>
							<xs:documentation>The difference between the amount on the invoice and the amount the customer paid in cash</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeKFZKennzeichenRequest">
