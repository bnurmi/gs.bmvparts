	<xs:complexType name="typeTeilelisteInfoResponse">
		<xs:annotation>
			<xs:documentation>For each part in the partlist a return code is given additionally to the information about the part</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The order number, if an order for this list exists</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummer" type="typeKundennummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The customer number, if a customer is assigned to the list</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="paketnummer" type="typePaketnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Package number, if the parts in the list are part of a package and flat rates are returned</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="paketpreis" type="typeDecimal9.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Net price of the package without discount</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="paketmehrwertsteuer" type="typeDecimal3.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Percentage of the VAT for the package.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="teilinformation" maxOccurs="unbounded">
						<xs:annotation>
							<xs:documentation>For each part in the list exists an element with the required information</xs:documentation>
						</xs:annotation>
						<xs:complexType>
							<xs:sequence>
								<xs:element ref="ergebnisCode" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Falls das DMS satzweise arbeitet, dann wird pro Satz ein Ergebniscode erzeugt. Dieser steht dann hier. Der übergeordnete Ergebniscode ist dann nicht relevant.</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="teilenummer" type="typeTeilenummer">
									<xs:annotation>
										<xs:documentation>The part number or flat rate number, see field art. </xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="art" type="typeNummernArt" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Kind of the number in field teilenummer. If not set the number is a part number. If the field is set to ARBEITSWERTNUMMER the number is a flat rate number.</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="bezeichnung" type="typeDMSTeilebezeichnung" minOccurs="0">
									<xs:annotation>
										<xs:documentation>The description of the part limited to 40 characters according to the format of the DMS. Must be set if art is TEILENUMMER, is not set if art is ARBEITSWERTNUMMER.</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="bedarfshinweis" type="typeBedarfshinweisCode" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Code of the remarks on requirements</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="AUME" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Outstanding quantity</xs:documentation>
									</xs:annotation>
									<xs:simpleType>
										<xs:restriction base="xs:decimal">
											<xs:totalDigits value="9"/>
											<xs:fractionDigits value="2"/>
										</xs:restriction>
									</xs:simpleType>
								</xs:element>
								<xs:element name="lagerort" type="typeLagerort" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Place of storage of the part</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="lagerbestand" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Inventory of the part in storage</xs:documentation>
									</xs:annotation>
									<xs:simpleType>
										<xs:restriction base="xs:decimal">
											<xs:totalDigits value="10"/>
											<xs:fractionDigits value="2"/>
										</xs:restriction>
									</xs:simpleType>
								</xs:element>
								<xs:element name="mindestbestand" type="typeDecimal8.2" minOccurs="0">
									<xs:annotation>
										<xs:documentation>The minimum inventory of the part. </xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="haendlerpreis" type="typeDecimal9.2">
									<xs:annotation>
										<xs:documentation>Price of the part or net price of the flat rate without discount if art is ARBEITSWERTNUMMER.</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="rabatt" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Percentage of the discount. This is a String, so +X meaning an addition instead of a reduction (X or -X) can be expressed.</xs:documentation>
									</xs:annotation>
									<xs:simpleType>
										<xs:restriction base="xs:string">
											<xs:minLength value="0"/>
											<xs:maxLength value="7"/>
										</xs:restriction>
									</xs:simpleType>
								</xs:element>
								<xs:element name="kodierungsstufe" type="typeKodierungsstufe" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Key of the discount</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="dispocode" type="typeOneDigitCode" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Dispocode, must be set if art is TEILENUMMER, is not set if art is ARBEITSWERTNUMMER.</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="suffix" type="typeOneDigitCode" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Suffix</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="mehrwertsteuer" type="typeDecimal3.2" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Percentage of the VAT</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="sondersteuer" type="typeDecimal3.2" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Percentage of the special tax</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:complexType>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeTeileinfoResponse">
		<xs:annotation>
			<xs:documentation>The information about the part</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="teilenummer" type="typeTeilenummer">
						<xs:annotation>
							<xs:documentation>The part number of the part for that the information is requested</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="bezeichnung" type="typeDMSTeilebezeichnung">
						<xs:annotation>
							<xs:documentation>The description of the part for that the information is requested limited to 40 characters as defined by DMS</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="haendlerpreis" type="typeDecimal9.2">
						<xs:annotation>
							<xs:documentation>Price of the part as defined in DMS</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="preisaenderungsdatum" type="xs:date" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The date of the last price change</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kodierungsstufe" type="typeKodierungsstufe" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Discount key</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="lagerort" type="typeLagerort" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Storage place of the part</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="lagerbestand" type="typeDecimal8.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Inventory of the part</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="mindestbestand" type="typeDecimal8.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The minimum inventory of the part. </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="mehrwertsteuer" type="typeDecimal3.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The VAT that is to be used for the part</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="sondersteuer" type="typeDecimal3.2" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The special tax that is to be used for the part</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeBestandsabfrageResponse">
		<xs:annotation>
			<xs:documentation>For each part in the partlist a return code is given additionally to the information about the part</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="bestandsinformation" maxOccurs="unbounded">
						<xs:annotation>
							<xs:documentation>For each part in the list exists an element with the required information</xs:documentation>
						</xs:annotation>
						<xs:complexType>
							<xs:sequence>
								<xs:element ref="ergebnisCode" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Falls das DMS satzweise arbeitet, dann wird pro Satz ein Ergebniscode erzeugt. Dieser steht dann hier. Der übergeordnete Ergebniscode ist dann nicht relevant.</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="teilenummer" type="typeTeilenummer">
									<xs:annotation>
										<xs:documentation>The part number </xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="lagerbestand">
									<xs:annotation>
										<xs:documentation>Inventory of the part in storage</xs:documentation>
									</xs:annotation>
									<xs:simpleType>
										<xs:restriction base="xs:decimal">
											<xs:totalDigits value="10"/>
											<xs:fractionDigits value="2"/>
										</xs:restriction>
									</xs:simpleType>
								</xs:element>
							</xs:sequence>
						</xs:complexType>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeFahrzeugidentResponse">
		<xs:annotation>
			<xs:documentation>The vehicle identification number deducted from the order number</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer">
						<xs:annotation>
							<xs:documentation>The order number that was used to identifiy the vehicle. This is the same value as the input parameter</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummer" type="typeKundennummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The customer number of the customer to whom the vehicle belongs</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundenname" type="typeString256" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The name of the customer limited to 20 characters</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="fahrgestellnummer" type="typeFahrgestellnummer">
						<xs:annotation>
							<xs:documentation>The vehicle identification number (VIN)</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="marke" type="typeMarke">
						<xs:annotation>
							<xs:documentation>The marque of the vehicle</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeEilauftragResponse">
		<xs:annotation>
			<xs:documentation>Return codes related to the rush order</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element ref="teilErgebnis" minOccurs="0" maxOccurs="unbounded"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeNeuteilauftragResponse">
		<xs:annotation>
			<xs:documentation>Return code for the order of the parts. For each part a separate return code can be provided</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element ref="teilErgebnis" minOccurs="0" maxOccurs="unbounded"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeFilialabfrageResponse">
		<xs:annotation>
			<xs:documentation>Information about the inventory of the branches according to the given part</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="filialErgebnis" maxOccurs="unbounded">
						<xs:annotation>
							<xs:documentation>For each part in the list exists one entry containing the information about the inventory in the branches</xs:documentation>
						</xs:annotation>
						<xs:complexType>
							<xs:sequence>
								<xs:element ref="teilErgebnis"/>
								<xs:element name="filialBestand" minOccurs="0" maxOccurs="unbounded">
									<xs:annotation>
										<xs:documentation>For each branch exists one entry for the current part</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:sequence>
											<xs:element name="filiale" type="typeFiliale">
												<xs:annotation>
													<xs:documentation>The branch</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="bestand" type="typeDecimal8.2">
												<xs:annotation>
													<xs:documentation>The inventory of the part in the branch</xs:documentation>
												</xs:annotation>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
							</xs:sequence>
						</xs:complexType>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeVerkaufAuftragResponse">
		<xs:annotation>
			<xs:documentation>As confirmation part number, order number and customer number are given</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The order number, if one exists</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element ref="teilErgebnis" maxOccurs="unbounded">
						<xs:annotation>
							<xs:documentation>die Teilenummer des gesendeten Teils</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="typeKFZKennzeichenResponse">
		<xs:annotation>
			<xs:documentation>The vehicle identification number deducted from the license number</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="typeDmsResponse">
				<xs:sequence>
					<xs:element name="auftragsnummer" type="typeAuftragsnummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The order number if one exists for the identified vehicle</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundennummer" type="typeKundennummer" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The customer number of the customer who is registered for the vehicle</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kundenname" type="typeString256" minOccurs="0">
						<xs:annotation>
							<xs:documentation>The name of the customer limited to 20 characters</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="fahrgestellnummer" type="typeFahrgestellnummer">
						<xs:annotation>
							<xs:documentation>The vehicle identification number (VIN)</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="marke" type="typeMarke">
						<xs:annotation>
							<xs:documentation>The marque of the vehicle</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<!--Globale Elemente, die wiederverwendet werden.-->
	<xs:element name="teilErgebnis">
		<xs:annotation>
			<xs:documentation>Many DMS function return for each given part a return code. This datatype covers that information. If the DMS works set oriented, multiple return codes are given.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="ergebnisCode" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Der Rückgabewert des DMS, wenn das DMS satzweise arbeitet.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="teilenummer" type="typeTeilenummer">
					<xs:annotation>
						<xs:documentation>The part number as a confirmation for successfull transmission</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="ergebnisCode" type="typeDMSErgebnisCodes">
		<xs:annotation>
			<xs:documentation>A valid return code from the DMS.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<!--Basiselement der Nachrichten an das und von dem DMS-->
	<xs:element name="dmsMessage">
		<xs:annotation>
			<xs:documentation>The main element for communication with the DMS via XML</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice>
				<xs:element name="dmsInit">
					<xs:annotation>
						<xs:documentation>The initialisation and retrieval of DMS sepcific information</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeInitRequest"/>
							<xs:element name="dmsResponse" type="typeInitResponse">
								<xs:unique name="UniqueMwstConstraint">
									<xs:selector xpath="typeMehrwertsteuerSatz"/>
									<xs:field xpath="mwstId"/>
								</xs:unique>
							</xs:element>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsStammsatzanlage">
					<xs:annotation>
						<xs:documentation>The creation of a master record for a given part</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeStammsatzanlageRequest"/>
							<xs:element name="dmsResponse" type="typeStammsatzanlageResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsTeileInfo">
					<xs:annotation>
						<xs:documentation>Request information about a given part</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeTeileinfoRequest"/>
							<xs:element name="dmsResponse" type="typeTeileinfoResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsTeilelistenInfo">
					<xs:annotation>
						<xs:documentation>Request information about the parts in the given partslist</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeTeilelisteInfoRequest"/>
							<xs:element name="dmsResponse" type="typeTeilelisteInfoResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsEilauftrag">
					<xs:annotation>
						<xs:documentation>Request to order a list of parts for several jobs and customers</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeEilauftragRequest"/>
							<xs:element name="dmsResponse" type="typeEilauftragResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsNeuteileAuftrag">
					<xs:annotation>
						<xs:documentation>Request to order a list of parts to restock the inventory and to get the new parts</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeNeuteilauftragRequest"/>
							<xs:element name="dmsResponse" type="typeNeuteilauftragResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsFilialabfrage">
					<xs:annotation>
						<xs:documentation>Request to retrieve the inventory for the given parts for each existing branch of the firm</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeFilialabfrageRequest"/>
							<xs:element name="dmsResponse" type="typeFilialabfrageResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsFzgIdAuftrag">
					<xs:annotation>
						<xs:documentation>Request to identify a vehicle by a given order number. The result is a vehicle identification number</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeFahrzeugidentRequest"/>
							<xs:element name="dmsResponse" type="typeFahrzeugidentResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsFzgIdKfzKennzeichen">
					<xs:annotation>
						<xs:documentation>Request to identify a vehicle by a given license plate number. The result is a vehicle identification number</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeKFZKennzeichenRequest"/>
							<xs:element name="dmsResponse" type="typeKFZKennzeichenResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsKostenvoranschlag">
					<xs:annotation>
						<xs:documentation>Request for a proposal for the given parts in the list</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeKostenvoranschlagRequest"/>
							<xs:element name="dmsResponse" type="typeVerkaufAuftragResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsWerkstattauftrag">
					<xs:annotation>
						<xs:documentation>Request to order parts related to a job or customer</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeWerkstattauftragRequest"/>
							<xs:element name="dmsResponse" type="typeVerkaufAuftragResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsBarverkauf">
					<xs:annotation>
						<xs:documentation>Request for a cash sale of the given parts</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeBarverkaufRequest"/>
							<xs:element name="dmsResponse" type="typeVerkaufAuftragResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
				<xs:element name="dmsBestandsabfrage">
					<xs:complexType>
						<xs:choice>
							<xs:element name="dmsRequest" type="typeBestandsabfrageRequest"/>
							<xs:element name="dmsResponse" type="typeBestandsabfrageResponse"/>
						</xs:choice>
					</xs:complexType>
				</xs:element>
			</xs:choice>
		</xs:complexType>
	</xs:element>
</xs:schema>
