CREATE VIEW sysblob(
	rsno, bcont
	) AS SELECT
	rsno, bcont
	FROM "@@sysblob";

CREATE VIEW syscolumn(
	tsegno,cname,ctype,domainname,defaultvalue,suppressed,cpos, ckey,notnull, surrid, surref
	) AS SELECT
	tsegno,cname,ctype,domainname,defaultvalue,suppressed,cpos,ckey,notnull, surrid, surref
	FROM "@@syscolumn"
	;

CREATE VIEW syscolumnpriv(
	grantee,tsegno,grantor, cpos, upd_priv
	) AS SELECT
	grantee,tsegno,grantor, cpos, upd_priv
	FROM "@@syscolumnpriv";

CREATE VIEW sysconstraint(
	segno,constraintname,attributes,constrainttext,cpos,ubtrees
	) AS SELECT
	segno,constraintname,attributes,constrainttext,cpos,ubtrees
	FROM "@@sysconstraint";

CREATE VIEW sysdomain(
	name, owner,basetype,defaultvalue,constraintname,
		attributes, constrainttext
	) AS SELECT
	name, owner,basetype,defaultvalue,constraintname,
		attributes, constrainttext
	FROM "@@sysdomain";

CREATE VIEW sysindex(
	tsegno,iname,weight,cpos,isuniq,isegno,indextype,wlistsegno,
	stowosegno,charmapsegno,delimsegno,ftxttype,wlisttype
	) AS SELECT
	tsegno,iname,weight,cpos,isuniq,isegno,indextype,wlistsegno,
	stowosegno,charmapsegno,delimsegno,ftxttype,wlisttype
	FROM "@@sysindex";

CREATE VIEW sysrefconstraint(
	constraintname,attributes,srcsegno,srccpos,
		tarsegno, tarcpos, delact, updact, matchtype
	) AS SELECT
	constraintname,attributes,srcsegno,srccpos,
		tarsegno, tarcpos, delact, updact, matchtype
	FROM "@@sysrefconstraint";

CREATE VIEW systable(
	tname,owner,ttype,segno,colno,"date","cluster",version,indextype
	) AS SELECT
	tname,owner,ttype,segno,colno,"date","cluster",version,indextype
	FROM "@@systable"
	WHERE tname NOT IN (
		'@@systable',
		'@@syscolumn',
		'@@sysindex',
		'@@sysuser',
		'@@sysview',
		'@@sysblob',
		'@@systablepriv',
		'@@syscolumnpriv',
		'@@sysviewdep',
		'@@sysdomain',
		'@@sysconstraint',
		'@@sysrefconstraint',
		'@@syssurrogate',
		'@@sysexternal',
		'@@sysexternalmethod',
		'@@sysexternalpriv',
		'@@systrigger'
		);

CREATE VIEW systablepriv(
	grantee,tsegno,grantor, sel_priv, del_priv, ins_priv, upd_priv
	) AS SELECT
	grantee,tsegno,grantor, sel_priv, del_priv, ins_priv, upd_priv
	FROM "@@systablepriv";

CREATE VIEW sysuser(
	username,userclass,passwd,userid
	) AS SELECT
	username,userclass,passwd,userid
	FROM "@@sysuser";

CREATE VIEW sysview(
	vsegno,viewtext,checkopt,updatable,viewtree
	) AS SELECT
	vsegno,viewtext,checkopt,updatable,viewtree
	FROM "@@sysview";

CREATE VIEW sysviewdep(
	basesegno, vsegno
	) AS SELECT
	basesegno, vsegno
	FROM "@@sysviewdep";

CREATE VIEW syssurrogate(
	surrid, segno, level, cpos, siblings
	) AS SELECT
	surrid, segno, level, cpos, siblings
	FROM "@@syssurrogate";

CREATE VIEW sysexternal(
	rkey, rtype, owner, enabled, debug, lastmodified,
	rname, rblob, sblob, comment) 
	AS SELECT
	rkey, rtype, owner, enabled, debug, lastmodified,
	rname, rblob, sblob, comment
	FROM "@@sysexternal";

CREATE VIEW sysexternalmethod(
	rkey, mkey, enabled, callonnull, determ, checkexcept,
	ownerrights, sqlaccess, dynasets, resulttype, sqlname,
	sqlsig, extsig, parammodes, paramnames, sqltabsig,
	exttabsig, methodname, comment)
	AS SELECT
	rkey, mkey, enabled, callonnull, determ	, checkexcept,
	ownerrights, sqlaccess, dynasets, resulttype, sqlname,
	sqlsig, extsig, parammodes, paramnames, sqltabsig,
	exttabsig, methodname, comment
	FROM "@@sysexternalmethod";

CREATE VIEW sysexternalpriv(
	grantee, rkey, mkey, grantor, use_priv)
	AS SELECT
	grantee, rkey, mkey, grantor, use_priv
	FROM "@@sysexternalpriv";

CREATE VIEW systrigger(
	triggername, owner, tsegno, event, aliasnew,aliasold,
	actions, firetime, statement_row, search_cond, creation_date,enabled)
	AS SELECT
	triggername, owner, tsegno, event, aliasnew,aliasold,
	actions, firetime, statement_row, search_cond, creation_date,enabled 
	FROM "@@systrigger";

GRANT SELECT ON sysblob TO PUBLIC;
GRANT SELECT ON syscolumn TO PUBLIC;
GRANT SELECT ON syscolumnpriv TO PUBLIC;
GRANT SELECT ON sysconstraint TO PUBLIC;
GRANT SELECT ON sysdomain TO PUBLIC;
GRANT SELECT ON sysindex TO PUBLIC;
GRANT SELECT ON sysrefconstraint TO PUBLIC;
GRANT SELECT ON systable TO PUBLIC;
GRANT SELECT ON systablepriv TO PUBLIC;
GRANT SELECT ON sysuser TO PUBLIC;
GRANT SELECT ON sysview TO PUBLIC;
GRANT SELECT ON sysviewdep TO PUBLIC;
GRANT SELECT ON syssurrogate TO PUBLIC;
GRANT SELECT ON sysexternal TO PUBLIC;
GRANT SELECT ON sysexternalmethod TO PUBLIC;
GRANT SELECT ON sysexternalpriv TO PUBLIC;
GRANT SELECT ON systrigger TO PUBLIC;

GRANT SELECT ON "@@sysblob" TO PUBLIC;
GRANT SELECT ON "@@syscolumn" TO PUBLIC;
GRANT SELECT ON "@@syscolumnpriv" TO PUBLIC;
GRANT SELECT ON "@@sysconstraint" TO PUBLIC;
GRANT SELECT ON "@@sysdomain" TO PUBLIC;
GRANT SELECT ON "@@sysindex" TO PUBLIC;
GRANT SELECT ON "@@sysrefconstraint" TO PUBLIC;
GRANT SELECT ON "@@systable" TO PUBLIC;
GRANT SELECT ON "@@systablepriv" TO PUBLIC;
GRANT SELECT ON "@@sysuser" TO PUBLIC;
GRANT SELECT ON "@@sysview" TO PUBLIC;
GRANT SELECT ON "@@sysviewdep" TO PUBLIC;
GRANT SELECT ON "@@syssurrogate" TO PUBLIC;
GRANT SELECT ON "@@sysexternal" TO PUBLIC;
GRANT SELECT ON "@@sysexternalmethod" TO PUBLIC;
GRANT SELECT ON "@@sysexternalpriv" TO PUBLIC;
GRANT SELECT ON "@@systrigger" TO PUBLIC;

UPDATE "@@systable" 
SET ttype='v' 
WHERE   tname IN (
	'sysblob',
	'syscolumn',
	'syscolumnpriv',
	'sysconstraint',
	'sysdomain',
	'sysindex',
	'sysrefconstraint',
	'systable',
	'systablepriv',
	'sysuser',
	'sysview',
	'sysviewdep',
	'syssurrogate',
	'sysexternal',
	'sysexternalmethod',
	'sysexternalpriv',
	'systrigger'
	)
;
create index sysconstraint_ix on "@@sysconstraint"(constraintname)
;
create index sysrefconstraint_ix on "@@sysrefconstraint"(constraintname)
;
create index systrigger_ix  on "@@systrigger"(
	tsegno, triggername, owner, event, aliasnew,aliasold, 
	actions, firetime, statement_row, search_cond, creation_date,enabled )
;
