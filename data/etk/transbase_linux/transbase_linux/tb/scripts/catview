; creation of 4 catalogue tables: 
; 		@@sysexternal, @@sysexternalmethod, @@sysexternalpriv
; 		@@systrigger

; create them with name which is not protected, then update
;  name in systable .. 
CREATE TABLE "@@@sysexternal" [ 105 ] (
	rkey		INTEGER NOT NULL,
	rtype		TINYINT NOT NULL,
	owner		INTEGER NOT NULL,
	enabled		BOOL NOT NULL,
	debug		BOOL NOT NULL,
	lastmodified	DATETIME[YY:SS],
	rname		CHAR(*) NOT NULL,
	rblob		BLOB,
	sblob		BLOB,
	comment		CHAR(*),
	d1		INTEGER,
	d2		CHAR(*))
KEY IS rkey,rname
;
CREATE TABLE "@@@sysexternalmethod" [ 113 ] (
	rkey		INTEGER NOT NULL,
	mkey		INTEGER NOT NULL,
	enabled		BOOL NOT NULL,
	callonnull	BOOL NOT NULL,
	determ		BOOL NOT NULL,
	checkexcept	BOOL NOT NULL,
	ownerrights	BOOL NOT NULL,
	sqlaccess	TINYINT NOT NULL,
	dynasets	TINYINT NOT NULL,
	resulttype	CHAR(1) NOT NULL,
	sqlname		CHAR(*) NOT NULL,
	sqlsig		CHAR(*) NOT NULL,
	extsig 		CHAR(*),
	parammodes	CHAR(*) NOT NULL,
	paramnames	CHAR(*),
	sqltabsig	CHAR(*),
	exttabsig 	CHAR(*),
	methodname	CHAR(*) NOT NULL,
	comment		CHAR(*),
	d1		INTEGER,
	d2		CHAR(*))
KEY IS sqlname,sqlsig
;
CREATE TABLE "@@@sysexternalpriv" [ 121 ] (
	grantee		INTEGER NOT NULL,
	rkey		INTEGER NOT NULL,
	mkey		INTEGER,
	grantor		INTEGER NOT NULL,
	use_priv	CHAR NOT NULL,
	d1		INTEGER,
	d2		CHAR(*))
KEY IS grantee, rkey, mkey
;
CREATE TABLE "@@@systrigger" [ 129 ] (
	triggername	CHAR(*) NOT NULL,
	owner		INTEGER NOT NULL,
	tsegno		INTEGER NOT NULL,
	event		CHAR(*) NOT NULL,  -- INSERT/DELETE/UPDATE OF a,b,c
	aliasnew	CHAR(*),
	aliasold	CHAR(*),
	actions		CHAR(*) NOT NULL,
	firetime	CHAR(*) NOT NULL,  -- BEFORE/AFTER
	statement_row 	CHAR(*) NOT NULL,  -- ROW/STATEMENT
	search_cond 	CHAR(*),
	creation_date	TIMESTAMP NOT NULL,
	enabled		INTEGER,
	d1		INTEGER,
	d2		CHAR(*))
KEY IS triggername
;

update "@@systable"
set tname = (if exists (select * from "@@systable"
		   where tname = '@@SYSTABLE' )
	     then '@@SYSEXTERNAL'
	     else '@@sysexternal'
	     fi)
where tname in ('@@@sysexternal', '@@@SYSEXTERNAL')
;
update "@@systable"
set tname = (if exists (select * from "@@systable"
		   where tname = '@@SYSTABLE' )
	     then '@@SYSEXTERNALMETHOD'
	     else '@@sysexternalmethod'
	     fi)
where tname in ('@@@sysexternalmethod', '@@@SYSEXTERNALMETHOD')
;
update "@@systable"
set tname = (if exists (select * from "@@systable"
		   where tname = '@@SYSTABLE' )
	     then '@@SYSEXTERNALPRIV'
	     else '@@sysexternalpriv'
	     fi)
where tname in ('@@@sysexternalpriv', '@@@SYSEXTERNALPRIV')
;
update "@@systable"
set tname = (if exists (select * from "@@systable"
		   where tname = '@@SYSTABLE' )
	     then '@@SYSTRIGGER'
	     else '@@systrigger'
	     fi)
where tname in ('@@@systrigger', '@@@SYSTRIGGER')
;


UPDATE "@@systable"
SET ttype = 'S'
where tname in ('@@sysexternal', '@@SYSEXTERNAL',
		'@@sysexternalmethod', '@@SYSEXTERNALMETHOD',
		'@@sysexternalpriv', '@@SYSEXTERNALPRIV',
		'@@systrigger', '@@SYSTRIGGER')
;

UPDATE "@@systable"
SET ttype = 'v'
where tname in ('sysexternal', 'SYSEXTERNAL',
		'sysexternalmethod', 'SYSEXTERNALMETHOD',
		'sysexternalpriv', 'SYSEXTERNALPRIV',
		'systrigger', 'SYSTRIGGER')
;

