# ─────────────────────────────────────────────────────────────────────────────
# BMW Parts Catalog — environment variables reference
# Copy this file to .env and fill in the values you need.
# All variables are optional unless marked REQUIRED.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED. PostgreSQL connection URL (set automatically by Replit managed DB).
DATABASE_URL=postgresql://user:pass@localhost:5432/bmvparts

# ── Session ───────────────────────────────────────────────────────────────────
# REQUIRED. Random secret used to sign session cookies.
SESSION_SECRET=change-me-to-a-random-64-char-string

# ── Evomi Core Residential proxy ──────────────────────────────────────────────
# Used for: ETK scraping (bmw-etk.info), VIN decoders, hash discovery.
# Cost: ~$0.49 / GB  |  Docs: https://evomi.com/documentation
EVOMI_PROXY_HOST=rp.evomi.com
EVOMI_PROXY_PORT=1000
EVOMI_PROXY_USERNAME=your_evomi_username
EVOMI_PROXY_PASSWORD=your_evomi_password
# http or https (default: https)
EVOMI_PROXY_SCHEME=https

# ── Evomi Premium Residential proxy ───────────────────────────────────────────
# Used as fallback for ETK / VIN decoder scrapers when Core is degraded.
# Cost: ~$5 / GB  |  Higher success rate, better geo coverage.
EVOMI_PREMIUM_PROXY_HOST=premium-rp.evomi.com
EVOMI_PREMIUM_PROXY_PORT=1000
EVOMI_PREMIUM_PROXY_USERNAME=your_evomi_username
EVOMI_PREMIUM_PROXY_PASSWORD=your_evomi_password
# http or https (default: https)
EVOMI_PREMIUM_PROXY_SCHEME=https

# ── Oxylabs Residential tunnel ────────────────────────────────────────────────
# Used as fallback for RealOEM / bimmer.work when Scraper API is unavailable.
# Cost: ~$7 / GB  |  Docs: https://developers.oxylabs.io/proxies/residential-proxies
OXYLABS_PROXY_HOST=pr.oxylabs.io
OXYLABS_PROXY_PORT=7777
OXYLABS_USERNAME=your_oxylabs_username
OXYLABS_PASSWORD=your_oxylabs_password

# ── Oxylabs Web Scraper API (Realtime Scraper) ────────────────────────────────
# PRIMARY for: RealOEM, bimmer.work  |  Handles Cloudflare / JS challenges.
# Cost: ~$150 / 220k results (~$68 / GB est.)
# The credentials are shared with the residential tunnel above (OXYLABS_USERNAME / OXYLABS_PASSWORD).
# Docs: https://developers.oxylabs.io/scraper-apis/web-scraper-api

# ── RealOEM daily request budget ──────────────────────────────────────────────
# Maximum RealOEM requests per UTC day before the fallback is rate-limited.
# Default: 7500
REALOEM_DAILY_BUDGET=7500

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for AI part identification (GPT-4o).  Managed via Replit AI Integrations
# — do not set OPENAI_API_KEY manually unless running outside Replit.
# OPENAI_API_KEY=sk-...

# ── Replit Object Storage ─────────────────────────────────────────────────────
# Automatically injected by Replit when Object Storage is attached.
# REPLIT_OBJECT_STORAGE_BUCKET_ID=...

# ── S3-compatible offsite backup mirror (optional) ────────────────────────────
S3_BACKUP_BUCKET=
S3_BACKUP_REGION=ap-southeast-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── Telegram alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email alerts (optional) ───────────────────────────────────────────────────
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── ISTA ingest scheduler ─────────────────────────────────────────────────────
# Set to 1 to disable the quarterly ISTA auto-ingest worker.
BMV_DISABLE_ISTA_SCHEDULER=0
# Poll interval in minutes (default: 360 = 6 hours)
ISTA_INGEST_POLL_MINUTES=360
# Email to alert on ISTA ingest failure
ISTA_ALERT_EMAIL=

# ── Catalog delta scheduler ───────────────────────────────────────────────────
# Set to 1 to disable the 24-hour delta catalog importer.
CATALOG_DELTA_DISABLED=0

# ── Carvertical affiliate ─────────────────────────────────────────────────────
# Custom tracking parameters appended to Carvertical mileage check links.
# CARVERTICAL_A=
# CARVERTICAL_B=

# ── Misc ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
